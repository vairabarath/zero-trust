# Controller Configuration
CONTROLLER_ADDR=localhost:50051
CONTROLLER_HTTP_ADDR=localhost:8080
TRUST_DOMAIN=mycorp.internal
CONTROLLER_ID=default

# Internal CA (for controller only)
INTERNAL_CA_CERT=<path-to-ca-cert>
INTERNAL_CA_KEY=<path-to-ca-key>

# Connector Configuration
CONNECTOR_ID=connector-01
CONNECTOR_LISTEN_ADDR=:9443
CONNECTOR_PRIVATE_IP=<private-ip>
CONNECTOR_VERSION=1.0.0
ENROLLMENT_TOKEN=<enrollment-token>
POLICY_SIGNING_KEY=<policy-signing-key>

# Agent Configuration
AGENT_ID=agent-01
CONNECTOR_ADDR=localhost:9443

# Database
DATABASE_PATH=./ztna.db

# Logging
LOG_LEVEL=info
