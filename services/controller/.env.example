# Controller configuration — copy to .env and fill in values

TRUST_DOMAIN=mycorp.internal
ADMIN_AUTH_TOKEN=<random-token>
INTERNAL_API_TOKEN=<random-token>
CONTROLLER_ADDR=localhost:8443
ADMIN_HTTP_ADDR=0.0.0.0:8081

# Database
# Leave DATABASE_URL empty to use SQLite (default). Set it for PostgreSQL.
DATABASE_URL=postgres://user:pass@localhost:5432/ztna?sslmode=disable
# DB_PATH=controller.db   # SQLite path (used when DATABASE_URL is empty)

# Google OAuth (leave GOOGLE_CLIENT_ID empty to disable)
GOOGLE_CLIENT_ID=<your-oauth-client-id>
GOOGLE_CLIENT_SECRET=<your-oauth-client-secret>
OAUTH_REDIRECT_URL=http://localhost:8081/oauth/callback
ADMIN_LOGIN_EMAILS=admin@example.com,other@example.com
JWT_SECRET=<random-secret>
DASHBOARD_URL=http://localhost:5173

# Email invites via SMTP (leave SMTP_HOST empty to disable, invite URL logged instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=<gmail-app-password>
SMTP_FROM=ZTNA Admin <youremail@gmail.com>
INVITE_BASE_URL=http://localhost:8081
